# Monorepo
/node_modules
/.DS_Store
/Thumbs.db

# Root env files
/.env
/.env.*
!/.env.example

# Frontend
/frontend/node_modules
/frontend/.next
/frontend/out
/frontend/build
/frontend/coverage
/frontend/.vercel
/frontend/.env*
!/frontend/.env.example
/frontend/*.tsbuildinfo

# Backend
/backend/node_modules
/backend/vendor
/backend/public/storage
/backend/public/build
/backend/public/hot
/backend/storage/*.key
/backend/storage/pail
/backend/.env
/backend/.env.*
!/backend/.env.example
